<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ticket Verification</title>
  <style>
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: #f0f4f8;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .wrapper {
      width: 640px;
      height: 960px;
      display: flex;
      flex-direction: column;
    }

    .card {
      flex: 1;
      background: #ffffff;
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0, 102, 255, 0.08);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
      padding: 48px 40px 40px;
      text-align: center;
    }

    .header-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      background: rgba(255, 255, 255, 0.18);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
    }

    .header h1 {
      color: #ffffff;
      font-size: 24px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .header p {
      color: rgba(255, 255, 255, 0.75);
      font-size: 14px;
      margin-top: 8px;
    }

    .body {
      flex: 1;
      padding: 40px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .status-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      margin-bottom: 24px;
      transition: all 0.3s ease;
    }

    .status-icon.loading {
      background: #E8F0FE;
      animation: pulse 1.5s ease-in-out infinite;
    }

    .status-icon.success {
      background: #E6F7EE;
    }

    .status-icon.expired {
      background: #FDE8E8;
    }

    .status-icon.error {
      background: #FEF3C7;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.08); opacity: 0.5; }
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid #0066FF;
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .status-title {
      font-size: 20px;
      font-weight: 600;
      color: #1a1a2e;
      margin-bottom: 12px;
    }

    .status-desc {
      font-size: 14px;
      color: #6b7280;
      line-height: 1.6;
      max-width: 420px;
    }

    .countdown {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #E8F0FE;
      color: #0066FF;
      font-size: 22px;
      font-weight: 700;
      margin: 20px 0;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 32px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.2s ease;
      border: none;
      margin-top: 24px;
    }

    .btn-primary {
      background: #0066FF;
      color: #ffffff;
    }

    .btn-primary:hover {
      background: #0052CC;
    }

    .btn-outline {
      background: transparent;
      color: #0066FF;
      border: 1.5px solid #0066FF;
    }

    .btn-outline:hover {
      background: #E8F0FE;
    }

    .footer {
      padding: 24px 40px;
      text-align: center;
      border-top: 1px solid #f0f0f0;
    }

    .footer span {
      font-size: 12px;
      color: #9ca3af;
    }

    .hidden {
      display: none !important;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="header-icon">&#128196;</div>
        <h1>Ticket Verification</h1>
        <p>Customer Support Center</p>
      </div>

      <div class="body">
        <div id="view-loading">
          <div class="status-icon loading">
            <div class="spinner"></div>
          </div>
          <div class="status-title">Verifying your ticket...</div>
          <div class="status-desc">Please wait while we validate your ticket link.</div>
        </div>

        <div id="view-success" class="hidden">
          <div class="status-icon success">&#10003;</div>
          <div class="status-title">Ticket Verified</div>
          <div class="status-desc">Your ticket is valid. You will be redirected automatically in</div>
          <div class="countdown" id="countdown-num">3</div>
          <div class="status-desc" style="font-size:13px; color:#9ca3af;">If not redirected, click the button below.</div>
          <a class="btn btn-primary" id="btn-redirect" href="#" target="_blank">Open Ticket Form &#8594;</a>
        </div>

        <div id="view-expired" class="hidden">
          <div class="status-icon expired">&#9888;</div>
          <div class="status-title">Link Expired</div>
          <div class="status-desc">This ticket link has already been used. Duplicate submissions are not allowed. If you believe this is an error, please create a new post in the forum.</div>
          <a class="btn btn-outline" href="https://discord.com" target="_blank">Return to Discord</a>
        </div>

        <div id="view-error" class="hidden">
          <div class="status-icon error">&#9888;</div>
          <div class="status-title">Invalid Link</div>
          <div class="status-desc">The ticket link appears to be invalid or has been tampered with. Please generate a new link from your forum post.</div>
          <a class="btn btn-outline" href="https://discord.com" target="_blank">Return to Discord</a>
        </div>
      </div>

      <div class="footer">
        <span>&copy; 2024 Customer Support. All rights reserved.</span>
      </div>
    </div>
  </div>

  <script>
    (function () {
      'use strict';

      var AES_KEY_HEX = 'a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6a7b8c9d0e1f2a3b4c5d6e1f2a3b4c5d6';
      var STORAGE_PREFIX = 'ticket_used_';
      var REDIRECT_DELAY = 3;

      var $loading = document.getElementById('view-loading');
      var $success = document.getElementById('view-success');
      var $expired = document.getElementById('view-expired');
      var $error = document.getElementById('view-error');
      var $countdownNum = document.getElementById('countdown-num');
      var $btnRedirect = document.getElementById('btn-redirect');

      function showView(view) {
        $loading.classList.add('hidden');
        $success.classList.add('hidden');
        $expired.classList.add('hidden');
        $error.classList.add('hidden');
        view.classList.remove('hidden');
      }

      function hexToBytes(hex) {
        var bytes = new Uint8Array(hex.length / 2);
        for (var i = 0; i < hex.length; i += 2) {
          bytes[i / 2] = parseInt(hex.substr(i, 2), 16);
        }
        return bytes;
      }

      function base64urlToBytes(str) {
        var base64 = str.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) {
          bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
      }

      function bytesToString(bytes) {
        return new TextDecoder().decode(bytes);
      }

      async function decryptToken(token) {
        var parts = token.split('.');
        if (parts.length !== 2) {
          throw new Error('Invalid token format');
        }

        var iv = base64urlToBytes(parts[0]);
        var data = base64urlToBytes(parts[1]);

        if (iv.length !== 12) {
          throw new Error('Invalid IV length');
        }

        var keyBytes = hexToBytes(AES_KEY_HEX);
        var cryptoKey = await crypto.subtle.importKey(
          'raw',
          keyBytes,
          { name: 'AES-GCM' },
          false,
          ['decrypt']
        );

        var decrypted = await crypto.subtle.decrypt(
          { name: 'AES-GCM', iv: iv },
          cryptoKey,
          data
        );

        return bytesToString(new Uint8Array(decrypted));
      }

      async function hashString(str) {
        var encoder = new TextEncoder();
        var data = encoder.encode(str);
        var hashBuffer = await crypto.subtle.digest('SHA-256', data);
        var hashArray = Array.from(new Uint8Array(hashBuffer));
        return hashArray.map(function (b) { return b.toString(16).padStart(2, '0'); }).join('');
      }

      function isVisited(storageKey) {
        return localStorage.getItem(STORAGE_PREFIX + storageKey) !== null;
      }

      function markVisited(storageKey) {
        localStorage.setItem(STORAGE_PREFIX + storageKey, Date.now().toString());
      }

      function getTokenFromURL() {
        var params = new URLSearchParams(window.location.search);
        return params.get('token');
      }

      function startCountdown(seconds, targetUrl) {
        var remaining = seconds;
        $countdownNum.textContent = remaining;

        var timer = setInterval(function () {
          remaining--;
          if (remaining <= 0) {
            clearInterval(timer);
            window.location.href = targetUrl;
            return;
          }
          $countdownNum.textContent = remaining;
        }, 1000);

        $btnRedirect.href = targetUrl;
      }

      async function main() {
        var token = getTokenFromURL();

        if (!token) {
          showView($error);
          return;
        }

        try {
          var originalUrl = await decryptToken(token);

          if (!originalUrl || !/^https?:\/\//.test(originalUrl)) {
            throw new Error('Decrypted data is not a valid URL');
          }

          var storageKey = await hashString(originalUrl);

          if (isVisited(storageKey)) {
            showView($expired);
            return;
          }

          markVisited(storageKey);
          showView($success);
          startCountdown(REDIRECT_DELAY, originalUrl);

        } catch (err) {
          console.error('Ticket verification failed:', err);
          showView($error);
        }
      }

      main();
    })();
  </script>
</body>
</html>
